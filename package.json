{
  "name": "migration-guard",
  "version": "0.2.0-rc.1",
  "description": "A behavior-consistency guardrail CLI for refactoring and migration work.",
  "type": "module",
  "bin": {
    "migration-guard": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node scripts/ci/run-tests.mjs",
    "ui:smoke": "npm run build && node scripts/smoke/ui-server-smoke.mjs",
    "start": "node dist/cli.js",
    "prepack": "npm run build",
    "package:smoke": "npm run build && node scripts/smoke/package-install-smoke.mjs",
    "pilot:smoke": "npm run build && node scripts/smoke/real-project-pilot.mjs",
    "package:audit": "npm run build && node scripts/ci/audit-package.mjs",
    "pilot:report": "node scripts/smoke/rc-feedback-report.mjs",
    "install:smoke": "npm run build && node scripts/smoke/install-modes-smoke.mjs",
    "release:gate": "node scripts/ci/release-gate.mjs"
  },
  "keywords": [
    "migration",
    "refactoring",
    "verification",
    "baseline",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "22.20.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/perly6185-lab/migration-guard.git"
  },
  "bugs": {
    "url": "https://github.com/perly6185-lab/migration-guard/issues"
  },
  "homepage": "https://github.com/perly6185-lab/migration-guard#readme"
}
