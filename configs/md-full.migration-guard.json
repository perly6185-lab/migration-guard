{
  "schemaVersion": 1,
  "targetRoot": "${MG_TARGET_ROOT}",
  "artifactsDir": "${MG_ARTIFACTS_DIR}/md-full",
  "variables": {
    "MG_TARGET_ROOT": "../../migration-guard-targets/md",
    "MG_ARTIFACTS_DIR": "../.migration-guard/external-targets",
    "MG_REPO_ROOT": "../../migration-guard"
  },
  "ignore": [
    ".git",
    "node_modules",
    "dist",
    "build",
    "coverage",
    ".next",
    ".nuxt",
    ".turbo",
    ".migration-guard",
    ".wxt",
    ".output"
  ],
  "checks": [
    {
      "name": "core-test",
      "command": "pnpm --filter @md/core test",
      "timeoutMs": 180000,
      "critical": true,
      "normalize": {
        "trimWhitespace": true,
        "presets": ["vitest", "paths", "timing"]
      }
    },
    {
      "name": "web-test",
      "command": "pnpm --filter @md/web test",
      "timeoutMs": 240000,
      "critical": true,
      "normalize": {
        "trimWhitespace": true,
        "presets": ["vitest", "paths", "timing"]
      }
    },
    {
      "name": "packages-type-check",
      "command": "pnpm type-check:packages",
      "timeoutMs": 240000,
      "critical": true,
      "normalize": {
        "trimWhitespace": true,
        "presets": ["paths", "timing"],
        "replace": [
          {
            "pattern": "(apps/api|packages/shared|packages/core) type-check(?:\\$ tsc --noEmit|: Done)",
            "replacement": "<type-check-step>"
          }
        ]
      }
    },
    {
      "name": "web-type-check",
      "command": "pnpm type-check:web",
      "timeoutMs": 300000,
      "critical": true,
      "normalize": {
        "trimWhitespace": true,
        "presets": ["paths", "timing"]
      }
    },
    {
      "name": "web-build",
      "command": "pnpm web build",
      "timeoutMs": 600000,
      "critical": false,
      "normalize": {
        "trimWhitespace": true,
        "presets": ["vite", "paths", "timing"]
      }
    }
  ],
  "probes": [
    {
      "type": "command",
      "name": "md-renderer-behavior",
      "command": "pnpm exec tsx ${MG_REPO_ROOT}/scripts/probes/md-behavior-probe.mjs",
      "timeoutMs": 120000,
      "normalize": {
        "stripAnsi": true,
        "trimWhitespace": true,
        "lineEndings": "lf",
        "json": {
          "sortKeys": true
        }
      }
    }
  ],
  "output": {
    "maxOutputBytes": 524288
  },
  "compare": {
    "failOnCheckRegression": true,
    "failOnProbeDiff": true
  }
}
